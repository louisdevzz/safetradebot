{
  "name": "safetradebot",
  "version": "1.0.0",
  "description": "Telegram bot theo dõi giá PRL/USDT trên SafeTrade",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node --esm src/index.ts",
    "dev:watch": "ts-node src/index.ts",
