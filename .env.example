# SafeTrade Price Bot - Cấu hình
# Copy file này thành .env và điền thông tin

# Token của Telegram Bot (lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Cặp giao dịch theo dõi (mặc định: prl-usdt)
MARKET_ID=prl-usdt

# SafeTrade API Key (tùy chọn - không cần cho public endpoints)
SAFETRADE_API_KEY=
SAFETRADE_SECRET_KEY=

# SaladCloud API (dùng cho /gpu)
SALAD_API_KEY=
SALAD_ORGANIZATION_NAME=louisa
